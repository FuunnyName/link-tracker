<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Continue to your link</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="card">
<h1>You're about to continue to an external link</h1>

<p>
Before we redirect you, thank you for participating in our research. This page is part of a study exploring how people interact with unfamiliar links and online prompts.
</p>

<p>
With your consent, we may collect limited technical information that websites commonly receive automatically, such as:
</p>

<ul>
  <li><strong>Whether you chose to continue</strong>, helping us understand how users respond to unfamiliar links.</li>
  <li><strong>Basic device information</strong> (such as browser, operating system, and device type), collected automatically in the same way as most websites.</li>
  <li><strong>Anonymous interaction data</strong>, including the time of your visit and how you navigated this page.</li>
  <li><strong>Optional feedback</strong>, if you choose to complete our short survey after the redirect.</li>
</ul>

<p>
Your participation is voluntary, and no personally identifying information is collected unless you explicitly provide it in the survey.
</p>
    <div id="status" class="status" style="display:none;"></div>

    <button id="continueBtn" class="btn">Allow location &amp; continue</button>
    <button id="skipBtn" class="btn btn-secondary">Continue without location</button>

    <p class="fineprint"></p>
  </div>

  <script>
    const slug = <%- JSON.stringify(slug) %>;
    const statusEl = document.getElementById('status');
    const continueBtn = document.getElementById('continueBtn');
    const skipBtn = document.getElementById('skipBtn');

    function setStatus(msg) {
      statusEl.style.display = 'block';
      statusEl.textContent = msg;
    }

    async function sendVisit(consented, location) {
      setStatus('Redirecting…');
      try {
        const resp = await fetch(`/api/visit/${slug}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ consented, location }),
        });
        const data = await resp.json();
        if (data.redirect) {
          window.location.replace(data.redirect);
        } else {
          setStatus('Something went wrong. Please try again.');
        }
      } catch (err) {
        setStatus('Something went wrong. Please try again.');
      }
    }

    continueBtn.addEventListener('click', () => {
      continueBtn.disabled = true;
      skipBtn.disabled = true;

      if (!navigator.geolocation) {
        setStatus('Location is not supported on this device. Continuing…');
        return sendVisit(false, null);
      }

      setStatus('Requesting location permission…');
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          sendVisit(true, {
            lat: pos.coords.latitude,
            lon: pos.coords.longitude,
            accuracy: pos.coords.accuracy,
          });
        },
        () => {
          setStatus('Location permission denied. Continuing…');
          sendVisit(false, null);
        },
        { enableHighAccuracy: true, timeout: 8000 }
      );
    });

    skipBtn.addEventListener('click', () => {
      continueBtn.disabled = true;
      skipBtn.disabled = true;
      sendVisit(false, null);
    });
  </script>
</body>
</html>
