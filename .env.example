# Copy this file to .env and fill in real values before running

# Port the server listens on
PORT=3000

# Password for the /admin dashboard (single admin user)
ADMIN_PASSWORD=change_this_password

# Random long string used to sign session cookies
SESSION_SECRET=change_this_to_a_long_random_string

# Your public base URL (used to build shareable links), e.g. https://links.example.com
BASE_URL=http://localhost:3000

# Optional: enable best-effort IP-based location fallback when the visitor
# denies/ignores the GPS permission prompt. Uses the free ip-api.com service
# (no key required, ~45 requests/min limit). Set to "false" to disable entirely.
ENABLE_IP_FALLBACK=true
